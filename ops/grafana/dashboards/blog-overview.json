{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(blog_cache_caffeine_hit_total[5m]) / (rate(blog_cache_caffeine_hit_total[5m]) + rate(blog_cache_caffeine_miss_total[5m]) + 1e-9)",
          "legendFormat": "Caffeine"
        },
        {
          "expr": "rate(blog_cache_redis_hit_total[5m]) / (rate(blog_cache_redis_hit_total[5m]) + rate(blog_cache_redis_miss_total[5m]) + 1e-9)",
          "legendFormat": "Redis"
        }
      ],
      "title": "缓存命中率",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        { "expr": "rate(blog_ratelimit_allowed_total[5m])", "legendFormat": "allowed" },
        { "expr": "rate(blog_ratelimit_rejected_total[5m])", "legendFormat": "rejected" }
      ],
      "title": "限流放行/拒绝",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(blog_http_server_requests_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(blog_http_server_requests_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "title": "HTTP P95/P99 (blog)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        { "expr": "rate(blog_http_slow_total[5m])", "legendFormat": "slow (>500ms)" }
      ],
      "title": "慢接口次数",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "targets": [
        { "expr": "jvm_memory_used_bytes{area=\"heap\"}", "legendFormat": "{{id}}" }
      ],
      "title": "JVM 堆内存",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "targets": [
        { "expr": "blog_chat_online_users", "legendFormat": "online" },
        { "expr": "blog_chat_offline_queue_length", "legendFormat": "offline_queue" },
        { "expr": "blog_chat_failed_queue_pending", "legendFormat": "failed_pending" },
        { "expr": "blog_chat_stream_lag", "legendFormat": "stream_lag" }
      ],
      "title": "聊天监控",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["personal-blog"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Personal Blog Overview",
  "uid": "blog-overview",
  "version": 1
}
