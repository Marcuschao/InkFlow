spring:
  cloud:
    nacos:
      username: nacos
      password: nacos
      discovery:
        server-addr: 127.0.0.1:8848
        port: 8082
        fail-fast: false
  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 10MB
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://127.0.0.1:3306/blog_db?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8&allowPublicKeyRetrieval=true
    username: root
    password: root
    hikari:
      maximum-pool-size: 20
      connection-timeout: 30000
      idle-timeout: 600000
      leak-detection-threshold: 60000

  data:
    redis:
      host: 127.0.0.1
      port: 6379
      database: 0
      timeout: 3000ms

  rabbitmq:
    host: 127.0.0.1
    port: 5672
    username: guest
    password: guest
    publisher-confirm-type: correlated
    publisher-returns: true
    listener:
      simple:
        acknowledge-mode: manual
        default-requeue-rejected: false

  security:
    jwt:
      secret: local-dev-jwt-secret-change-me
      expiration: 43200
      remember-me-expiration: 604800

blog:
  site-url: http://127.0.0.1:5173
  site-base-path: /pblog
  oauth:
    enabled: false
  notify-mail-enabled: false

minio:
  enabled: true
  endpoint: http://127.0.0.1:9005
  access-key: minioadmin
  secret-key: minioadmin
  public-base-url: http://127.0.0.1:9005
  buckets:
    chat: blog-chat
    avatars: blog-avatars
    diary: blog-diary
    versions: blog-versions
    logs: blog-logs
    reports: blog-reports
    backups: blog-backups

logging:
  level:
    root: INFO
    com.blog.auth: DEBUG
