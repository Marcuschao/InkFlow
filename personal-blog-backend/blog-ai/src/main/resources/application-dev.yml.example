spring:
  cloud:
    nacos:
      username: nacos
      password: CHANGE_ME_NACOS_PASSWORD
      discovery:
        server-addr: 172.18.0.7:8848
        ip: YOUR_PUBLIC_IP
        port: 8084
        fail-fast: false
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://172.18.0.5:3306/blog_db?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8&allowPublicKeyRetrieval=true
    username: internal_app
    password: CHANGE_ME_MYSQL_PASSWORD
    hikari:
      maximum-pool-size: 10
      connection-timeout: 30000
      idle-timeout: 600000
      leak-detection-threshold: 60000

  rabbitmq:
    host: 172.18.0.2
    port: 5672
    username: YOUR_RABBITMQ_USER
    password: CHANGE_ME_RABBITMQ_PASSWORD

  data:
    redis:
      host: 172.18.0.3
      port: 6379
      password: CHANGE_ME_REDIS_PASSWORD
      database: 1
      timeout: 3000

  security:
    jwt:
      secret: CHANGE_ME_JWT_SECRET
      expiration: 43200
      remember-me-expiration: 604800

  ai:
    openai:
      api-key: CHANGE_ME_AI_API_KEY
      base-url: https://api.deepseek.com
      chat:
        options:
          model: deepseek-chat
          temperature: 0.7
          max-tokens: 1024

blog:
  site-url: http://YOUR_DOMAIN:PORT
  site-base-path: /pblog
  oauth:
    enabled: false
  notify-mail-enabled: false

minio:
  enabled: true
  endpoint: http://172.18.0.4:9000
  access-key: YOUR_MINIO_ACCESS_KEY
  secret-key: CHANGE_ME_MINIO_SECRET_KEY
  public-base-url: http://YOUR_DOMAIN:PORT/minio
  buckets:
    chat: blog-chat
    avatars: blog-avatars
    diary: blog-diary
    versions: blog-versions
    logs: blog-logs
    reports: blog-reports
    backups: blog-backups

logging:
  level:
    root: WARN
    com.blog.ai: INFO
